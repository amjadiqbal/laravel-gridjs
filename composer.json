{
  "name": "amjadiqbal/laravel-gridjs",
  "description": "The modern, dependency-free Datagrid for Laravel. A powerful Grid.js wrapper with Eloquent support, server-side pagination, and an elegant fluent API.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "gridjs",
    "datagrid",
    "eloquent",
    "pagination",
    "search",
    "sortable"
  ],
  "homepage": "https://github.com/amjadiqbal/laravel-gridjs",
  "authors": [
    {
      "name": "Amjad Iqbal"
    }
  ],
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/database": "^10.0|^11.0",
    "illuminate/routing": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "pestphp/pest": "^2.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "AmjadIqbal\\GridJS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AmjadIqbal\\GridJS\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AmjadIqbal\\GridJS\\GridServiceProvider"
      ],
      "aliases": {
        "Grid": "AmjadIqbal\\GridJS\\Facades\\Grid"
      }
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
